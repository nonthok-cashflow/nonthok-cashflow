# Copy to .env and fill in your Alpaca paper-trading credentials.
# Get them from: https://app.alpaca.markets/paper-trading (Paper Trading section)

APP__ALPACA__API_KEY=your_paper_api_key_here
APP__ALPACA__API_SECRET=your_paper_api_secret_here
APP__ALPACA__PAPER=true

# Optionally override trading limits
APP__TRADING__MAX_ORDER_SIZE_USD=1000.0
APP__TRADING__MAX_OPEN_POSITIONS=5
APP__TRADING__RISK_PER_TRADE_PCT=0.01

# Logging level: trace | debug | info | warn | error
APP__LOGGING__LEVEL=info
